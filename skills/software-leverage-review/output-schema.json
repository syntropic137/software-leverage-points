{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://syntropic137.dev/software-leverage-points/output-schema.json",
  "title": "Software Leverage Review Output",
  "description": "Authoritative schema for findings emitted by per-leverage-point subagents and by the software-leverage-review orchestrator.",
  "$defs": {
    "Finding": {
      "type": "object",
      "required": ["severity", "issue", "suggested_fix"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["error", "warn", "info"]
        },
        "issue": {
          "type": "string",
          "minLength": 1
        },
        "suggested_fix": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 0
        },
        "lens_violations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["dry", "principles-and-patterns", "software-complexity"]
          },
          "uniqueItems": true
        },
        "software_leverage_point": {
          "type": "string",
          "description": "Optional on per-LP findings; populated on findings inside the merged orchestrator shape so the source LP is preserved."
        }
      }
    },
    "PerLeveragePointOutput": {
      "type": "object",
      "required": ["software_leverage_point", "findings", "summary"],
      "additionalProperties": false,
      "properties": {
        "software_leverage_point": {
          "type": "string",
          "minLength": 1
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/Finding" }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "MergedOrchestratorOutput": {
      "type": "object",
      "required": [
        "target",
        "software_leverage_points_reviewed",
        "findings",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "software_leverage_points_reviewed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/Finding" }
        },
        "lens_synthesis": {
          "type": "array",
          "items": { "$ref": "#/$defs/Finding" }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/PerLeveragePointOutput" },
    { "$ref": "#/$defs/MergedOrchestratorOutput" }
  ]
}
