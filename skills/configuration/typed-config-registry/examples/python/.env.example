# .env.example
#
# Generated from config.py. Do not hand-edit; run the generator instead.
# Copy to .env and fill in environment-specific values.

# Application name. Used in logs and metric tags.
APP_NAME=example-service

# Current environment. Affects logging verbosity, error surface, and which
# feature defaults apply.
APP_ENVIRONMENT=development

# Enable debug mode. Shows detailed errors. Never enable in production.
DEBUG=false

# Postgres DSN. Format: postgresql://user:password@host:port/database. Required
# in production. Defaults to None so a missing override fails fast rather than
# silently pointing at localhost.
DATABASE_URL=

# Connection pool size. Increase for high-traffic production.
DATABASE_POOL_SIZE=5

# HTTP client request timeout. Increase for slow downstreams.
REQUEST_TIMEOUT_SECONDS=30

# Number of retries on transient HTTP failures.
REQUEST_RETRY_COUNT=3

# Third-party API key. Loaded from secret store (1Password, Vault, or
# cloud-native). Never committed to source.
API_KEY=

# Set true to disable the background poller in this deployment.
POLLING_DISABLED=false

# Set true to disable metrics emission. Default-on for stable observability.
METRICS_DISABLED=false
