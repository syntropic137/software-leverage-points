# .env.example
#
# Generated from env.ts. Do not hand-edit; run the generator instead.
# Copy to .env and fill in environment-specific values.

# Current environment: development | staging | production | test. Affects
# logging verbosity and feature defaults.
APP_ENVIRONMENT=

# Postgres DSN. Format: postgresql://user:password@host:port/database. Required
# in production. No safe default exists.
# Required: yes
# Suggested op:// ref: op://Personal/example-project/database_url
DATABASE_URL=

# Third-party API key. Loaded from secret store. Never committed to source.
# Suggested op:// ref: op://Personal/example-project/api_key
API_KEY=

# Set 'true' to force-disable the background poller on this host. Default-on;
# explicit opt-out.
POLLING_DISABLED=

# Set 'true' to disable metrics emission. Default-on for stable observability.
METRICS_DISABLED=
